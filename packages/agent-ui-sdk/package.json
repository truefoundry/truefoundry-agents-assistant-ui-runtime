{
  "name": "@truefoundry/agent-ui-sdk",
  "version": "0.1.0",
  "description": "Design-system-agnostic Atom/Container UI SDK for TrueFoundry agent chat, built on assistant-ui.",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./openui.css": "./src/openui.css"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "sideEffects": [
    "src/openui.css",
    "dist/openui.css"
  ],
  "scripts": {
    "prepare": "tsup",
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@assistant-ui/react": "^0.14.0",
    "@types/react": "*",
    "react": "^18 || ^19",
    "truefoundry-agents-assistant-ui-runtime": "workspace:*",
    "truefoundry-gateway-sdk": "0.2.0-rc.1"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  },
  "dependencies": {
    "@openuidev/react-lang": "^0.2.8",
    "@openuidev/react-ui": "^0.12.1",
    "@assistant-ui/core": "^0.2.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "radix-ui": "^1.6.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@assistant-ui/react": "^0.14.24",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19.2.17",
    "jsdom": "^24.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "truefoundry-agents-assistant-ui-runtime": "workspace:*",
    "truefoundry-gateway-sdk": "0.2.0-rc.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
