  "dependencies": {
    "@assistant-ui/core": "^0.2.19",
    "@assistant-ui/store": "^0.2.19"
  },
  "peerDependencies": {
    "@types/react": "*",
    "react": "^18 || ^19",
    "truefoundry-gateway-sdk": "0.2.0-rc.1"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19.2.17",
    "jsdom": "^29.1.1",
    "react": "^19.2.4",
    "truefoundry-gateway-sdk": "0.2.0-rc.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
